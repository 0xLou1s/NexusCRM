# Copy to .env and fill in. .env is git-ignored; this template is committed.
# Every variable the code reads is listed here — when a PR introduces a new one,
# it lands in this file in the same PR. The block at the bottom is the exception:
# those are declared by the spec but not yet consumed, and each says which phase
# starts reading it.
#
# Passwords go into the URLs percent-encoded: a raw "@" is the delimiter
# between credentials and host, so "p@ss" must be written "p%40ss" or the
# connection string parses against the wrong host.

# --- apps/api ---------------------------------------------------------------

NODE_ENV=development
PORT=3001

# The one origin allowed to send credentialed requests. The session is a cookie,
# and a browser refuses "*" together with cookies — so this is an exact origin,
# never a wildcard.
WEB_ORIGIN=http://localhost:3000

# Signs the access token (spec §6). At least 32 characters, and the API refuses
# to boot without it — a default secret is a forgeable session.
#   openssl rand -base64 48
JWT_SECRET=<generate-me>

# --- apps/web ---------------------------------------------------------------
# The API the browser talks to. `NEXT_PUBLIC_` because it is read in the browser,
# where the session cookie is sent with every request — so this is also the
# origin that WEB_ORIGIN above must let through CORS.

NEXT_PUBLIC_API_URL=http://localhost:3001

# --- redis: apps/api + apps/zalo-worker --------------------------------------
# The only channel between api and zalo-worker: api enqueues BullMQ jobs, the
# worker consumes them (spec §3.2). Matches a stock local Redis
# (`docker run -p 6379:6379 redis`); the compose service arrives in PR 0.7.

REDIS_URL=redis://localhost:6379

# --- `pnpm gen:api-types` ----------------------------------------------------
# The API the frontend's types are generated from: the script reads
# <API_URL>/openapi.json. Point it at a deployed environment to pick up a
# backend branch you have not checked out.

API_URL=http://localhost:3001

# --- packages/db ------------------------------------------------------------
# Both come from the Supabase dashboard: top bar -> "Connect". Same host and
# user, different port and pooling mode.

# Transaction pooler, port 6543. The path the running apps take.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Session pooler, port 5432. drizzle-kit only: DDL and the advisory locks
# migrations take do not survive the transaction pooler.
DIRECT_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- declared by the spec, not read by any code yet --------------------------
# Listed now so `docker compose up` and a fresh clone have one complete
# template, rather than discovering a missing variable per phase. None of these
# are in a Zod env schema yet: a schema only validates what the app consumes,
# and a required-but-unused variable would fail boot for no reason.

# Every day boundary is computed in this zone, never in UTC and never hard-coded
# (spec §6.2): the 200-message cap resets at local midnight, the reminder job
# runs at 08:00 local, and report ranges follow it. Phase 6.
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Supabase Storage — the media bucket is private, so the service key is what
# signs upload and download URLs (spec §5.4). Both come from the Supabase
# dashboard: Project Settings -> API. Phase 6.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# AES-GCM key for Zalo session blobs and webhook secrets (spec §4.2). A leaked
# database means a stolen Zalo account if these are stored in plaintext.
# Phase 3. Exactly 32 bytes:
#   openssl rand -hex 32
ENCRYPTION_KEY=<generate-me>
