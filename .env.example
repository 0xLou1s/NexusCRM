# Copy to .env and fill in. .env is git-ignored; this template is committed.
# Every variable the code actually reads is listed here — when a PR introduces
# a new one, it lands in this file in the same PR.
#
# Passwords go into the URLs percent-encoded: a raw "@" is the delimiter
# between credentials and host, so "p@ss" must be written "p%40ss" or the
# connection string parses against the wrong host.

# --- apps/api ---------------------------------------------------------------

NODE_ENV=development
PORT=3001

# The one origin allowed to send credentialed requests. The session is a cookie,
# and a browser refuses "*" together with cookies — so this is an exact origin,
# never a wildcard.
WEB_ORIGIN=http://localhost:3000

# --- `pnpm gen:api-types` ----------------------------------------------------
# The API the frontend's types are generated from: the script reads
# <API_URL>/openapi.json. Point it at a deployed environment to pick up a
# backend branch you have not checked out.

API_URL=http://localhost:3001

# --- packages/db ------------------------------------------------------------
# Both come from the Supabase dashboard: top bar -> "Connect". Same host and
# user, different port and pooling mode.

# Transaction pooler, port 6543. The path the running apps take.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Session pooler, port 5432. drizzle-kit only: DDL and the advisory locks
# migrations take do not survive the transaction pooler.
DIRECT_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
